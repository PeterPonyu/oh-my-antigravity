{
  "name": "oh-my-antigrav",
  "version": "0.0.0-private",
  "private": true,
  "description": "oh-my-antigrav experimental beta: a clean-room local agent-harness scaffold.",
  "type": "module",
  "license": "MIT",
  "author": "Zeyu Fu",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PeterPonyu/oh-my-antigravity.git"
  },
  "bugs": {
    "url": "https://github.com/PeterPonyu/oh-my-antigravity/issues"
  },
  "homepage": "https://github.com/PeterPonyu/oh-my-antigravity#readme",
  "keywords": [
    "oh-my-antigrav",
    "agent-harness",
    "clean-room",
    "experimental",
    "beta",
    "local-first"
  ],
  "bin": {
    "oh-my-antigrav": "dist/cli.js",
    "oag": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "NOTICE.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "start": "node ./src/cli.ts",
    "cli:help": "node ./src/cli.ts --help",
    "cli:status": "node ./src/cli.ts status",
    "cli:version": "node ./src/cli.ts --version",
    "build": "tsc -p tsconfig.build.json && node -e \"require('fs').chmodSync('dist/cli.js', 0o755)\"",
    "prepack": "npm run build",
    "typecheck": "tsc --noEmit",
    "lint": "node ./scripts/verify.mjs --lint-only",
    "inventory:validate": "node ./scripts/validate-surface-inventory.mjs",
    "verify:suite": "node ./scripts/suite-verification.mjs",
    "test": "node --test",
    "audit:negative": "node ./scripts/verify.mjs --audit-only",
    "audit:deps": "npm audit --audit-level=high",
    "smoke:pack": "node ./scripts/pack-smoke.mjs",
    "verify": "npm run typecheck && npm run lint && npm run inventory:validate && npm test && npm run cli:help && npm run cli:status && npm run cli:version && npm run audit:negative"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^6.0.3"
  }
}
